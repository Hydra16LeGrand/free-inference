# --- PostgreSQL ---
POSTGRES_USER=litellm
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=litellm

# --- vLLM ---
VLLM_API_KEY=sk-vllm-local-secret
HF_TOKEN=hf_your_token_here_if_needed

# --- LiteLLM ---
LITELLM_MASTER_KEY=sk-litellm-master-secret
LITELLM_SALT_KEY=sk-litellm-salt-secret

# --- Open WebUI ---
# Doit etre une chaine aleatoire d'au moins 32 caracteres en production.
WEBUI_SECRET_KEY=webui-secret-key-change-me

# --- Ngrok ---
NGROK_AUTHTOKEN=your_ngrok_token_here
NGROK_DOMAIN=
NGROK_BASIC_AUTH=user:password

# --- Grafana ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
