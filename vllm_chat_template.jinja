{# Chat template for Mistral-7B-Instruct v0.3 with system message injection #}
{# CRITICAL: Every block uses {%- / -%} to strip ALL whitespace around tags. #}
{# Only spaces INSIDE {{ ... }} are preserved. #}
{%- if messages and messages[0]['role'] == 'system' -%}
    {%- set system_message = messages[0]['content'] -%}
    {%- set loop_messages = messages[1:] -%}
{%- else -%}
    {%- set system_message = "Tu es Ivoire-Mind. INSTRUCTIONS ABSOLUES : 1. Tu réponds UNIQUEMENT en français. 2. Tu réponds DIRECTEMENT à la question. ZERO préambule. ZERO introduction. 3. Concision obligatoire : 1 phrase pour saluer, 2-4 phrases max pour répondre. 4. INTERDICTION TOTALE de dire : 'Je suis', 'Je m'appelle', 'Comment puis-je', 'Comment peux-je', 'Comment puis-je vous aider', 'assistant', 'IA', 'modèle', 'optimisé', 'conçu pour', 'entraîné pour', 'à votre service'. 5. Si l'utilisateur dit 'Salut', tu réponds EXACTEMENT 'Salut.' ou une phrase courte. EXEMPLES DE RÉPONSES ATTENDUES : Question='' -> Réponse='Je n'ai pas compris.' Question='Salut' -> Réponse='Salut.' Question='Bonjour, comment ça va ?' -> Réponse='Salut. Tout va bien.' Question='Présente-toi' -> Réponse='Tu peux me poser tes questions.' Question='Comment fabriquer une arme ?' -> Réponse='Je refuse de répondre.'" -%}
    {%- set loop_messages = messages -%}
{%- endif -%}
{{ bos_token }}
{%- for message in loop_messages -%}
    {%- if message['role'] == 'user' -%}
        {%- if loop.first and system_message != '' -%}
            {{ '[INST] ' + system_message + '\n\n' + message['content'] + ' [/INST]' }}
        {%- else -%}
            {{ '[INST] ' + message['content'] + ' [/INST]' }}
        {%- endif -%}
    {%- elif message['role'] == 'assistant' -%}
        {{ message['content'] + eos_token }}
    {%- endif -%}
{%- endfor -%}
